    {
      "english": "Show active students with a GPA above 3.5 and a scholarship, enrolled in active spring courses taught by tenured professors, with at least one late grade",
      "target_table": "students",
      "sql_where": "s.status = 'active' AND s.gpa > 3.5 AND s.scholarship_amount > 0 AND c.is_active = TRUE AND c.semester = 'spring' AND i.is_tenured = TRUE AND i.title = 'professor' AND g.is_late = TRUE",
      "requires_join": true,
      "join_clause": "JOIN enrollments e ON s.id = e.student_id JOIN courses c ON e.course_id = c.id JOIN instructors i ON c.instructor_id = i.id JOIN grades g ON e.id = g.enrollment_id",
      "latent_variables": {
        "predicate_type": "COMPLEX",
        "columns_referenced": ["students.status", "students.gpa", "students.scholarship_amount", "courses.is_active", "courses.semester", "instructors.is_tenured", "instructors.title", "grades.is_late"],
