        },
        {
          "name": "is_active",
          "type": "BOOLEAN",
          "default": true
        }
      ]
    },
    {
      "name": "appointments",
      "columns": [
        {
          "name": "id",
          "type": "INT",
          "primary_key": true
        },
        {
          "name": "patient_id",
          "type": "INT",
          "foreign_key": "patients.id"
        },
        {
          "name": "doctor_id",
          "type": "INT",
          "foreign_key": "doctors.id"
        },
        {
          "name": "scheduled_at",
