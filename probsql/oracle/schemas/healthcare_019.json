        {
          "name": "unit",
          "type": "VARCHAR(20)",
          "nullable": true
        },
        {
          "name": "is_abnormal",
          "type": "BOOLEAN",
          "default": false
        },
        {
          "name": "doctor_id",
          "type": "INT",
          "foreign_key": "doctors.id"
        }
      ]
    },
