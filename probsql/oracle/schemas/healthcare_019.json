      "type": "many_to_one"
    },
    {
      "from": "prescriptions.patient_id",
      "to": "patients.id",
      "type": "many_to_one"
    },
    {
      "from": "prescriptions.doctor_id",
      "to": "doctors.id",
      "type": "many_to_one"
    },
    {
      "from": "appointments.patient_id",
      "to": "patients.id",
      "type": "many_to_one"
    },
    {
      "from": "appointments.doctor_id",
      "to": "doctors.id",
      "type": "many_to_one"
    }
  ]
}