            "female",
            "other"
          ]
        },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "nullable": false
        },
        {
          "name": "phone",
          "type": "VARCHAR(20)",
          "nullable": true
        },
        {
          "name": "emergency_contact",
          "type": "VARCHAR(100)",
          "nullable": true
        }
      ]
    },
    {
      "name": "lab_results",
      "columns": [
