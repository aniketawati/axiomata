{
  "schema_id": "logistics_018",
  "domain": "logistics",
  "tables": [
    {
      "name": "routes",
      "columns": [
        {
          "name": "id",
          "type": "INT",
          "primary_key": true
        },
        {
          "name": "origin",
          "type": "VARCHAR(200)",
          "nullable": false
        },
        {
          "name": "destination",
          "type": "VARCHAR(200)",
          "nullable": false
        },
        {
          "name": "distance_km",
          "type": "FLOAT",
          "nullable": false
        },
        {
          "name": "cost_per_kg",
          "type": "DECIMAL(10,2)",
          "nullable": true
        },
        {
          "name": "carrier_id",
          "type": "INT",
          "foreign_key": "carriers.id"
        },
        {
          "name": "frequency",
          "type": "VARCHAR(20)",
          "enum_values": [
            "daily",
            "weekly",
            "biweekly",
            "monthly"
          ]
        },
        {
          "name": "estimated_hours",
          "type": "FLOAT",
          "nullable": true
        },
        {
          "name": "is_active",
          "type": "BOOLEAN",
          "default": true
        }
      ]
    },
    {
      "name": "inventory",
      "columns": [
        {
          "name": "id",
          "type": "INT",
          "primary_key": true
        },
        {
          "name": "warehouse_id",
          "type": "INT",
          "foreign_key": "warehouses.id"
        },
        {
          "name": "sku",
          "type": "VARCHAR(50)",
          "nullable": false
        },
        {
          "name": "quantity",
          "type": "INT",
          "nullable": false
        },
        {
          "name": "min_quantity",
          "type": "INT",
          "default": 10
        },
        {
          "name": "expiry_date",
          "type": "DATE",
          "nullable": true
        },
        {
          "name": "is_perishable",
          "type": "BOOLEAN",
          "default": false
        },
        {
          "name": "max_quantity",
          "type": "INT",
          "nullable": true
        },
        {
          "name": "product_name",
          "type": "VARCHAR(200)",
          "nullable": true
        },
        {
          "name": "last_restocked_at",
          "type": "TIMESTAMP",
          "nullable": true
        }
      ]
    },
    {
      "name": "carriers",
      "columns": [
        {
          "name": "id",
          "type": "INT",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "VARCHAR(100)",
          "nullable": false
        },
        {
          "name": "type",
          "type": "VARCHAR(20)",
          "enum_values": [
            "ground",
            "air",
            "sea",
            "rail"
          ]
        },
        {
          "name": "phone",
          "type": "VARCHAR(20)",
          "nullable": true
        },
        {
          "name": "on_time_percentage",
          "type": "FLOAT",
          "nullable": true
        }
      ]
    },
    {
      "name": "shipments",
      "columns": [
        {
          "name": "id",
          "type": "INT",
          "primary_key": true
        },
        {
          "name": "tracking_number",
          "type": "VARCHAR(50)",
          "nullable": false,
          "unique": true
        },
        {
          "name": "origin",
          "type": "VARCHAR(200)",
          "nullable": false
        },
        {
          "name": "destination",
          "type": "VARCHAR(200)",
          "nullable": false
        },
        {
          "name": "status",
          "type": "VARCHAR(20)",
          "enum_values": [
            "created",
            "picked_up",
            "in_transit",
            "out_for_delivery",
            "delivered",
            "returned"
          ]
        },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "nullable": false
        },
        {
          "name": "estimated_delivery",
          "type": "TIMESTAMP",
          "nullable": true
        },
        {
          "name": "is_express",
          "type": "BOOLEAN",
          "default": false
        },
        {
          "name": "carrier_id",
          "type": "INT",
          "foreign_key": "carriers.id"
        },
        {
          "name": "is_fragile",
          "type": "BOOLEAN",
          "default": false
        },
        {
          "name": "shipping_cost",
          "type": "DECIMAL(10,2)",
          "nullable": true
        },
        {
          "name": "warehouse_id",
          "type": "INT",
          "foreign_key": "warehouses.id"
        }
      ]
    },
    {
      "name": "warehouses",
      "columns": [
        {
          "name": "id",
          "type": "INT",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "VARCHAR(100)",
          "nullable": false
        },
        {
          "name": "location",
          "type": "VARCHAR(200)",
          "nullable": false
        },
        {
          "name": "capacity",
          "type": "INT",
          "nullable": false
        },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "nullable": false
        },
        {
          "name": "current_utilization",
          "type": "FLOAT",
          "nullable": true
        },
        {
          "name": "manager_name",
          "type": "VARCHAR(100)",
          "nullable": true
        },
        {
          "name": "type",
          "type": "VARCHAR(20)",
          "enum_values": [
            "standard",
            "cold_storage",
            "hazmat",
            "bulk"
          ]
        }
      ]
    }
  ],
  "relationships": [
    {
      "from": "routes.carrier_id",
      "to": "carriers.id",
      "type": "many_to_one"
    },
    {
      "from": "inventory.warehouse_id",
      "to": "warehouses.id",
      "type": "many_to_one"
    },
    {
      "from": "shipments.carrier_id",
      "to": "carriers.id",
      "type": "many_to_one"
    },
    {
      "from": "shipments.warehouse_id",
      "to": "warehouses.id",
      "type": "many_to_one"
    }
  ]
}