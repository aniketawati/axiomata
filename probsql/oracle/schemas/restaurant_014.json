  "relationships": [
    {
      "from": "menus.restaurant_id",
      "to": "restaurants.id",
      "type": "many_to_one"
    },
    {
      "from": "reservations.restaurant_id",
      "to": "restaurants.id",
      "type": "many_to_one"
    }
  ]
}