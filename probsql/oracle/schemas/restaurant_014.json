          "type": "INT",
          "primary_key": true
        },
        {
          "name": "name",
          "type": "VARCHAR(200)",
          "nullable": false
        },
        {
          "name": "cuisine_type",
          "type": "VARCHAR(50)",
          "nullable": true
        },
        {
          "name": "address",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "has_takeout",
          "type": "BOOLEAN",
          "default": true
        },
        {
          "name": "phone",
          "type": "VARCHAR(20)",
          "nullable": true
        }
      ]
    },
    {
      "name": "menus",
      "columns": [
        {
