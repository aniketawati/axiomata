            "appetizer",
            "main",
            "dessert",
            "drink",
            "side",
            "special"
          ]
        },
        {
          "name": "spice_level",
          "type": "VARCHAR(10)",
          "enum_values": [
            "mild",
            "medium",
            "hot",
            "extra_hot"
          ]
        },
        {
          "name": "preparation_time_min",
          "type": "INT",
          "nullable": true
        },
        {
          "name": "is_vegetarian",
          "type": "BOOLEAN",
          "default": false
        },
        {
          "name": "description",
          "type": "TEXT",
          "nullable": true
        },
        {
          "name": "calories",
          "type": "INT",
          "nullable": true
        },
        {
          "name": "is_vegan",
          "type": "BOOLEAN",
          "default": false
        }
      ]
    },
    {
      "name": "reservations",
      "columns": [
        {
          "name": "id",
          "type": "INT",
          "primary_key": true
        },
        {
          "name": "restaurant_id",
          "type": "INT",
          "foreign_key": "restaurants.id"
        },
        {
          "name": "customer_name",
          "type": "VARCHAR(100)",
          "nullable": false
        },
        {
          "name": "party_size",
          "type": "INT",
          "nullable": false
        },
        {
          "name": "reserved_at",
          "type": "TIMESTAMP",
          "nullable": false
        },
        {
          "name": "status",
          "type": "VARCHAR(20)",
          "enum_values": [
